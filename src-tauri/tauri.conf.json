{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemas/master/tauri/v2/tauri.conf.schema.json",
  "productName": "HYJI",
  "version": "0.1.3",
  "identifier": "com.hyji.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HYJI — Highlight Your Journey of Insights",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:hyji.db"]
    },
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/inyoungoh-cde/hyji/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJCMTQxMjFGNzA5MDg3ODUKUldTRmg1QndIeElVdTgxVE14bDhBK2RQelVyOFlvVXZSQnBKMUN6dkF4WFFDUy9vMTEvT200OTcK"
    }
  }
}
